DATABASE_URL=postgresql://user:password@host:5432/postgres

# Supabase Auth JWT secret (Project Settings -> API -> JWT Secret), used to
# verify the Authorization: Bearer <token> header on Keeper routes.
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Supabase Storage — used to store uploaded/recorded audio files.
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=audio

# Redis connection string for the ARQ AI pipeline job queue.
REDIS_URL=redis://localhost:6379
