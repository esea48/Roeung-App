DATABASE_URL=postgresql://user:password@host:5432/postgres

# Supabase Auth JWT secret (Project Settings -> API -> JWT Secret), used to
# verify the Authorization: Bearer <token> header on Keeper routes.
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Supabase Storage — used to store uploaded/recorded audio files.
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=audio

# Redis connection string for the ARQ AI pipeline job queue.
REDIS_URL=redis://localhost:6379

# OpenAI — GPT-4o-mini translation, cultural review, title generation, people flagging.
OPENAI_API_KEY=

# LangSmith observability for the AI pipeline.
LANGSMITH_API_KEY=
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=roeung-ai

# AI pipeline thresholds (optional — defaults shown).
AUDIO_QUALITY_THRESHOLD=0.5
TRANSLATION_CONFIDENCE_THRESHOLD=0.7

# Staging smoke test configuration.
SMOKE_API_BASE_URL=http://localhost:8000
SMOKE_FAMILY_ACCESS_TOKEN=replace-with-family-access-token
SMOKE_KEEPER_TOKEN=replace-with-keeper-jwt
SMOKE_AUDIO_PATH=/absolute/path/to/audio-fixture.wav
SMOKE_NARRATOR_NAME=Smoke Test Narrator
SMOKE_RECORDER_NAME=Smoke Test Recorder
SMOKE_CONSENT_WORDING_KEY=v1_uploaded
SMOKE_TIMEOUT_SECONDS=600
SMOKE_POLL_INTERVAL_SECONDS=5

# CORS — allowed browser origin. Change to the deployed frontend URL in production.
FRONTEND_ORIGIN=http://localhost:5173
