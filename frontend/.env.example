# Copy to .env and fill in your values before running the frontend.

# Backend URL for the Vite dev-server proxy. Leave as-is for local development.
VITE_API_PROXY_TARGET=http://localhost:8000

# Supabase project URL — used by keeperClient.js for Keeper email/password auth.
# Find in: Supabase dashboard > Project Settings > API > Project URL
VITE_SUPABASE_URL=

# Supabase anon/public key — safe to expose in the browser.
# Find in: Supabase dashboard > Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=
